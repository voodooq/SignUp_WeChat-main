# MongoDB 连接
MONGODB_URL=mongodb://mongo:27017
MONGODB_DB_NAME=sign_wechat

# 服务端口
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# 微信小程序配置
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# 微信支付（第二阶段配置）
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=
WECHAT_SUBSCRIBE_TEMPLATE_ID=

# 安全密钥
AES_SECRET_KEY=your_aes_secret_key_32_chars_long!
JWT_SECRET_KEY=your_jwt_secret_key_change_this_in_production

# JWT Token 有效期（小时）
JWT_EXPIRE_HOURS=168

# 模拟支付开关（生产环境设为 false）
ENABLE_MOCK_PAY=true

# 文件上传
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5

# CORS 允许的域名（逗号分隔）
CORS_ORIGINS=*
